# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# local database snapshots
/data/*.db
/data/*.db-wal
/data/*.db-shm

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# cloudflare / opennext
.open-next/
.wrangler/
cloudflare-env.d.ts

# typescript
*.tsbuildinfo
next-env.d.ts
.env
.env.*
!.env.example
.saasmaker.json

# fallow cache
.fallow/
cache.bin

# CF Pages build output
.cf-pages-bundle/
