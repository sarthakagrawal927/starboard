{
  "name": "starboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed-embeddings": "tsx src/db/seed-embeddings.ts",
    "db:embed-pending": "tsx src/db/seed-embeddings.ts",
    "db:seed-popular": "tsx scripts/seed-popular.ts",
    "cf:build": "next build --webpack && opennextjs-cloudflare build --skipNextBuild",
    "build:cf": "next build --webpack && opennextjs-cloudflare build --skipNextBuild",
    "preview:cf": "pnpm build:cf && opennextjs-cloudflare preview",
    "deploy:cf": "pnpm build:cf && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@libsql/client": "0.17.3",
    "@saas-maker/changelog-widget": "^0.2.1",
    "@saas-maker/feedback": "^0.2.1",
    "@saas-maker/sdk": "^0.3.1",
    "@saas-maker/testimonials": "^0.2.1",
    "@tanstack/react-virtual": "3.13.24",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "lucide-react": "1.11.0",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "0.4.6",
    "nuqs": "2.8.9",
    "radix-ui": "1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "swr": "2.4.1",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.19.4",
    "@saas-maker/eslint-config": "^1.0.4",
    "@saas-maker/prettier-config": "^1.0.0",
    "@saas-maker/tsconfig": "^1.0.0",
    "@tailwindcss/postcss": "4",
    "@types/node": "25.6.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "10.2.1",
    "eslint-config-next": "16.2.4",
    "husky": "9.1.7",
    "shadcn": "4.4.0",
    "tailwindcss": "4",
    "tsx": "^4.21.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "wrangler": "4.85.0"
  },
  "prettier": "@saas-maker/prettier-config",
  "pnpm": {
    "patchedDependencies": {
      "eslint-plugin-react@7.37.5": "patches/eslint-plugin-react@7.37.5.patch"
    }
  }
}
